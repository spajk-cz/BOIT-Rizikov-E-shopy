{
  "manifest_version": 3,
  "name": "BOIT Rizikové E-shopy",
  "short_name": "BOIT Rizikové E-shopy",
  "version": "1.7.0",
  "description": "Varuje vás při návštěvě rizikových e-shopů ze seznamů ČOI (CZ) a SOI (SK). Navíc detekuje další podvodné signály.",
  "author": "BOIT Cyber Security s.r.o.",
  "homepage_url": "https://boit.cz",
  "minimum_chrome_version": "110",

  "permissions": [
    "storage",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "https://coi.gov.cz/*",
    "https://www.soi.sk/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://*.google.com/*",
        "https://*.googleusercontent.com/*",
        "https://accounts.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "BOIT Rizikové E-shopy",
    "default_icon": {
      "16": "icons/icon-safe-16.png",
      "32": "icons/icon-safe-32.png",
      "48": "icons/icon-safe-48.png",
      "128": "icons/icon-safe-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-safe-16.png",
    "32": "icons/icon-safe-32.png",
    "48": "icons/icon-safe-48.png",
    "128": "icons/icon-safe-128.png"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self'; img-src 'self' data:; connect-src 'self' https://coi.gov.cz https://www.soi.sk;"
  }
}
